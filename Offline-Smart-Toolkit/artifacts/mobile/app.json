{
  "expo": {
    "name": "CSC Smart Toolkit",
    "slug": "csc-smart-toolkit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cscsmartoolkit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cscsmarttoolkit.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "CSC Smart Toolkit needs photo library access to save exported images and documents.",
        "NSPhotoLibraryAddUsageDescription": "CSC Smart Toolkit saves exported images (QR codes, stamps, signatures, photos) to your photo library.",
        "NSCameraUsageDescription": "CSC Smart Toolkit needs camera access to scan barcodes and QR codes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1D4ED8"
      },
      "package": "com.cscsmarttoolkit.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "onnxruntime-react-native",
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "CSC Smart Toolkit needs camera access to scan QR codes and barcodes.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "CSC Smart Toolkit needs photo library access to process your images.",
          "cameraPermission": "CSC Smart Toolkit needs camera access to capture images."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "CSC Smart Toolkit needs access to your photo library to save exported images.",
          "savePhotosPermission": "CSC Smart Toolkit needs permission to save images to your photo library.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ee7f25cc-3c2b-4319-99e2-593dc5b4bd1d"
      }
    },
    "owner": "testtttttttheees-team"
  }
}
