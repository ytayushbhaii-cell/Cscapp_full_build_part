{
  "expo": {
    "name": "CSC Smart Toolkit",
    "slug": "csc-smart-toolkit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cscsmartoolkit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cscsmarttoolkit.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "CSC Smart Toolkit needs photo library access to save exported images and documents.",
        "NSPhotoLibraryAddUsageDescription": "CSC Smart Toolkit saves exported images (QR codes, stamps, signatures, photos) to your photo library.",
        "NSCameraUsageDescription": "CSC Smart Toolkit needs camera access to scan barcodes and QR codes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1D4ED8"
      },
      "package": "com.cscsmarttoolkit.app",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F172A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
